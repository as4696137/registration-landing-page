{
  "$schema": "https://design-tokens.org/schemas/v1.0.0/design-tokens.schema.json",
  "name": "初聲 Contest Design Tokens",
  "version": "1.0.0",
  "$description": "Neo-brutalist design tokens extracted from the existing contest site (black hairline borders, hard offset shadows, fluorescent accent blocks).",
  "color": {
    "primitive": {
      "white": { "$type": "color", "$value": "#ffffff" },
      "black": { "$type": "color", "$value": "#000000" },
      "gray": {
        "100": { "$type": "color", "$value": "#e6e6e6", "$description": "Light divider / disabled fill" },
        "500": { "$type": "color", "$value": "#888888", "$description": "Muted text / placeholder" },
        "700": { "$type": "color", "$value": "#333333", "$description": "Body text on light surfaces" }
      },
      "yellow": {
        "neon": { "$type": "color", "$value": "#ffff41", "$description": "Signature primary accent" },
        "pure": { "$type": "color", "$value": "#ffff00", "$description": "Hover underline accent" }
      },
      "blue": { "pure": { "$type": "color", "$value": "#0000ff", "$description": "Grid background / link accent" } },
      "green": {
        "light": { "$type": "color", "$value": "#92f590", "$description": "Section background" },
        "bright": { "$type": "color", "$value": "#4af864" },
        "mint": { "$type": "color", "$value": "#92f590" }
      },
      "teal": {
        "bright": { "$type": "color", "$value": "#00ffc7", "$description": "Tag fill" },
        "soft": { "$type": "color", "$value": "#9bf3e0" }
      },
      "pink": { "bright": { "$type": "color", "$value": "#ff6996", "$description": "Tag fill" } }
    },
    "semantic": {
      "brand": {
        "primary": { "$type": "color", "$value": "{color.primitive.yellow.neon}", "$description": "Primary accent for highlighted titles & key blocks" },
        "primary-hover": { "$type": "color", "$value": "{color.primitive.yellow.pure}" }
      },
      "text": {
        "primary": { "$type": "color", "$value": "{color.primitive.black}", "$description": "Default text" },
        "secondary": { "$type": "color", "$value": "{color.primitive.gray.700}" },
        "muted": { "$type": "color", "$value": "{color.primitive.gray.500}" },
        "inverse": { "$type": "color", "$value": "{color.primitive.white}", "$description": "Text on black surfaces (navbar)" },
        "accent": { "$type": "color", "$value": "{color.primitive.yellow.neon}", "$description": "Highlighted text on dark (nav hover)" }
      },
      "background": {
        "primary": { "$type": "color", "$value": "{color.primitive.white}", "$description": "Default surface / cards" },
        "inverse": { "$type": "color", "$value": "{color.primitive.black}", "$description": "Navbar / footer" },
        "accent": { "$type": "color", "$value": "{color.primitive.green.light}", "$description": "Section backdrop" }
      },
      "border": {
        "default": { "$type": "color", "$value": "{color.primitive.black}", "$description": "Universal 1px hairline border" }
      },
      "tag": {
        "yellow": { "$type": "color", "$value": "{color.primitive.yellow.neon}" },
        "teal": { "$type": "color", "$value": "{color.primitive.teal.bright}" },
        "pink": { "$type": "color", "$value": "{color.primitive.pink.bright}" }
      }
    }
  },
  "typography": {
    "fontFamily": {
      "display": { "$type": "fontFamily", "$value": "'Dela Gothic One', cursive", "$description": "Headings / hero titles" },
      "sans": { "$type": "fontFamily", "$value": "'Noto Sans TC', sans-serif", "$description": "Body / UI text" }
    },
    "fontSize": {
      "base": { "$type": "dimension", "$value": "1rem", "$description": "16px - body / nav links" },
      "lg": { "$type": "dimension", "$value": "1.125rem", "$description": "18px" },
      "xl": { "$type": "dimension", "$value": "1.25rem", "$description": "20px - card lead" },
      "2xl": { "$type": "dimension", "$value": "1.5rem", "$description": "24px - tag label" },
      "4xl": { "$type": "dimension", "$value": "2.25rem", "$description": "36px - sub heading (mobile)" },
      "5xl": { "$type": "dimension", "$value": "3rem", "$description": "48px - section sub heading" },
      "display-sm": { "$type": "dimension", "$value": "40px", "$description": "Heading (compact viewport)" },
      "display-md": { "$type": "dimension", "$value": "65px" },
      "display-lg": { "$type": "dimension", "$value": "80px", "$description": "Hero / section title" }
    },
    "fontWeight": {
      "medium": { "$type": "fontWeight", "$value": 500 },
      "bold": { "$type": "fontWeight", "$value": 700 }
    },
    "lineHeight": {
      "none": { "$type": "number", "$value": 1, "$description": "Base body reset" },
      "title": { "$type": "number", "$value": 1.2, "$description": "120% - display headings" },
      "body": { "$type": "number", "$value": 1.6, "$description": "160% - card paragraphs" }
    }
  },
  "spacing": {
    "1.5": { "$type": "dimension", "$value": "0.375rem", "$description": "6px - tight avatar pad" },
    "2": { "$type": "dimension", "$value": "0.5rem", "$description": "8px - tag padding-y" },
    "2.5": { "$type": "dimension", "$value": "0.625rem", "$description": "10px - avatar pad" },
    "4": { "$type": "dimension", "$value": "1rem", "$description": "16px - tag/card padding-x" },
    "5": { "$type": "dimension", "$value": "1.25rem", "$description": "20px - card padding-x" },
    "10": { "$type": "dimension", "$value": "2.5rem", "$description": "40px" },
    "20": { "$type": "dimension", "$value": "5rem", "$description": "80px - section title gap" }
  },
  "borderRadius": {
    "none": { "$type": "dimension", "$value": "0", "$description": "Default for blocks/cards/tags" },
    "full": { "$type": "dimension", "$value": "9999px", "$description": "Avatars / icon buttons" }
  },
  "borderWidth": {
    "hairline": { "$type": "dimension", "$value": "1px", "$description": "Universal black border" }
  },
  "shadow": {
    "hard-sm": {
      "$type": "shadow",
      "$value": { "offsetX": "0", "offsetY": "5px", "blur": "0", "spread": "0", "color": "rgba(0, 0, 0, 0.25)" },
      "$description": "Hard offset shadow, small"
    },
    "hard-md": {
      "$type": "shadow",
      "$value": { "offsetX": "0", "offsetY": "10px", "blur": "0", "spread": "0", "color": "rgba(0, 0, 0, 0.25)" },
      "$description": "Signature card/tag shadow"
    },
    "hard-lg": {
      "$type": "shadow",
      "$value": { "offsetX": "0", "offsetY": "15px", "blur": "0", "spread": "0", "color": "rgba(0, 0, 0, 0.25)" }
    },
    "hard-diagonal": {
      "$type": "shadow",
      "$value": { "offsetX": "10px", "offsetY": "15px", "blur": "0", "spread": "0", "color": "rgba(0, 0, 0, 0.25)" }
    },
    "hard-solid": {
      "$type": "shadow",
      "$value": { "offsetX": "0", "offsetY": "10px", "blur": "0", "spread": "0", "color": "rgba(0, 0, 0, 1)" },
      "$description": "Opaque variant for title drop-shadow stacks"
    }
  },
  "component": {
    "tag": {
      "padding": { "x": { "$type": "dimension", "$value": "{spacing.4}" }, "y": { "$type": "dimension", "$value": "{spacing.2}" } },
      "fontSize": { "$type": "dimension", "$value": "{typography.fontSize.2xl}" },
      "fontWeight": { "$type": "fontWeight", "$value": "{typography.fontWeight.bold}" },
      "border": { "$type": "color", "$value": "{color.semantic.border.default}" },
      "shadow": { "$type": "shadow", "$value": "{shadow.hard-md}" }
    },
    "card": {
      "padding": { "x": { "$type": "dimension", "$value": "{spacing.5}" }, "y": { "$type": "dimension", "$value": "1rem" } },
      "background": { "$type": "color", "$value": "{color.semantic.background.primary}" },
      "border": { "$type": "color", "$value": "{color.semantic.border.default}" },
      "shadow": { "$type": "shadow", "$value": "{shadow.hard-md}" }
    },
    "avatar": {
      "borderRadius": { "$type": "dimension", "$value": "{borderRadius.full}" },
      "padding": { "$type": "dimension", "$value": "{spacing.2.5}" },
      "border": { "$type": "color", "$value": "{color.semantic.border.default}" },
      "shadow": { "$type": "shadow", "$value": "{shadow.hard-md}" }
    }
  }
}
